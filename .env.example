# Copy this to .env and fill in your token (or use token.txt instead).
TELEGRAM_BOT_TOKEN=123456789:PASTE-YOUR-TOKEN-FROM-BOTFATHER

# Who may use this bot. Comma-separated Telegram user ids. Leave empty and the bot
# answers ANYONE (not recommended). Send the bot /start (or ask @userinfobot) for your id.
#
# ORDER MATTERS. The FIRST id is the MASTER: the human who drives this bot and receives
# every proactive notification (status/watchdog, startup ping, [HARNESS] messages,
# intrusion alerts). The MASTER must open a chat with the bot (send it /start) or those
# messages fail with "Chat not found". Every other id is a GUEST: a guest may use the bot
# (their replies land in their OWN chat) but gets NO notifications and need not be the
# machine's owner. So to hand a bot to someone else while keeping your own backup access,
# list THEM first and yourself second:  ALLOWED_USER_IDS=<their-id>,<your-id>
# ALLOWED_USER_IDS=123456789

# Canonical/default bot for THIS install: the session loaded on startup and in single-bot mode.
# Must match a bots/<name>/ directory; falls back to 'claude' if unset or the named bot is missing.
# DEFAULT_BOT=ava

# Default model for sessions with no per-bot model (bots/<name>/config.json "model").
# Without this, the CLI falls back to the machine's ~/.claude/settings.json model —
# pin it so a global setting (e.g. fable) can't silently become the bots' default.
# ANTHROPIC_MODEL=opus

# Optional knobs (defaults are tuned for MAX ACCURACY):
# WHISPER_MODEL=large-v3       # tiny|base|small|medium|large-v3 (default: large-v3)
# WHISPER_COMPUTE_TYPE=float32 # full precision (default). int8 = ~3-4x faster, tiny accuracy loss
# WHISPER_LANGUAGE=en          # force a language; omit to auto-detect
# WHISPER_DEVICE=cpu           # cpu|cuda
