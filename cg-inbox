#!/usr/bin/env bash
# cg-inbox — read messages the user sent from the phone via `bot harness <text>`.
#
# For the AI/harness working on this machine: this is how the user talks back to you.
#   (no args) : print pending messages (oldest first) and DRAIN them (consume once)
#   --peek    : print without draining (leave them for the next read)
#   --wait    : block until a message arrives, then print + drain it (loop primitive:
#               `while true; do ./cg-inbox --wait; done` to monitor continuously)
#
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INBOX="$HERE/inbox"
mkdir -p "$INBOX"

mode="drain"
case "${1:-}" in
  --peek) mode="peek" ;;
  --wait) mode="wait" ;;
  "")     : ;;
  *) echo "usage: cg-inbox [--peek|--wait]" >&2; exit 2 ;;
esac

if [ "$mode" = "wait" ]; then
  while ! compgen -G "$INBOX/*.msg" >/dev/null; do sleep 2; done
fi

found=0
for f in "$INBOX"/*.msg; do
  [ -e "$f" ] || continue
  found=1
  ns="$(basename "$f" .msg)"
  secs=$(( ns / 1000000000 ))
  when="$(date -d "@$secs" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo "$secs")"
  echo "── [$when] ──────────────────────────────"
  cat "$f"; echo
  [ "$mode" != "peek" ] && rm -f "$f"
done
if [ "$found" -eq 0 ]; then
  echo "(inbox empty)"
else
  echo "──────────────────────────────────────────"
  echo "⚠️  ACK REQUIRED: the user is on their PHONE and CANNOT see this terminal."
  echo "    For the message(s) above, immediately send an outbox ack describing what"
  echo "    you're doing about it:  ./cg-notify \"got it — <action / answer>\""
  echo "    Printing to your own output is NOT enough — they won't see it."
fi
exit 0
