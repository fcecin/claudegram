#!/usr/bin/env bash
set -euo pipefail

root="${1:?usage: splice-plan <root> [--pattern <glob>] [--exclude <path>]...}"
shift
pattern="*"; excludes=()
while [ $# -gt 0 ]; do
  case "$1" in
    --pattern) pattern="$2"; shift 2 ;;
    --exclude) excludes+=("-not" "-path" "$2"); shift 2 ;;
    *) echo "unknown option: $1" >&2; exit 1 ;;
  esac
done
root="$(readlink -f "$root")" || { echo "splice-plan: no such root" >&2; exit 1; }

find "$root" -type f -name "$pattern" "${excludes[@]}" \
  | sed 's|/[^/]*$||' \
  | sort -u \
  | while read -r dir; do
      count=$(find "$dir" -maxdepth 1 -type f -name "$pattern" 2>/dev/null | wc -l)
      [ "$count" -gt 0 ] && echo "$count $dir"
    done \
  | sort -n \
  | cut -d' ' -f2-
